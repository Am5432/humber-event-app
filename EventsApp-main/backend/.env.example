# Humber Event Hub — backend environment configuration
# Copy this file to backend/.env and fill in real values.
# backend/.env must NEVER be committed to git.

# Authentication provider: "mock" (default) or "firebase"
EVENT_APP_AUTH_PROVIDER=firebase

# Firebase project ID (from Firebase Console -> Project settings)
EVENT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase service account credentials as a minified single-line JSON string.
# Obtain from Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# Paste the entire JSON on one line, enclosed in double quotes.
EVENT_APP_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Database (defaults to SQLite in backend directory — usually no change needed)
# EVENT_APP_DATABASE_URL=sqlite:///./event_hub.db
